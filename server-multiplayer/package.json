{
  "name": "minesweeper-multiplayer-server",
  "version": "1.0.0",
  "description": "Multiplayer server for 3D Minesweeper (no YouTube features)",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "start": "npx tsx server.ts",
    "dev": "npx tsx --watch server.ts",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "typescript": "^5.9.3"
  }
}